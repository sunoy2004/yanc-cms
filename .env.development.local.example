# Copy to .env.development.local to use the API running on your machine (e.g. npm run dev in apps/cms-api).
# Vite loads this in development and it overrides .env.local, so login will go to your local API.
# VITE_API_URL=http://localhost:8080/api
# VITE_CMS_BASE_URL=http://localhost:8080
# VITE_CMS_API_URL=http://localhost:8080
